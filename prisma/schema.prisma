generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Preorder {
  id           String   @id @default(cuid())
  title        String
  customerName String
  email        String?
  phone        String?
  quantity     Int      @default(1)
  price        Float
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
